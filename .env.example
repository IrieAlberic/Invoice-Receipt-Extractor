# ─── Free AI Vision / LLM Providers ─────────────────────────────────────────
# Google Gemini — FREE: 1,500 req/day via Google AI Studio
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key

# Groq — FREE: generous daily quota with LPU speed
# Get key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_key

# Mistral — FREE credits at signup
# Get key: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your_mistral_key

# HuggingFace — FREE: Inference API (rate-limited)
# Get key: https://huggingface.co/settings/tokens
HF_API_KEY=your_hf_key

# DeepSeek — FREE: generous free tier
# Get key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_key

# ─── Free OCR Cloud APIs ──────────────────────────────────────────────────────
# OCR.space — FREE: 25,000 requests/month
# Get key: https://ocr.space/ocrapi (use 'helloworld' for quick tests)
OCR_SPACE_API_KEY=helloworld

# Mindee — FREE: 250 predictions/month
# Get key: https://platform.mindee.com/
MINDEE_API_KEY=your_mindee_key

# ─── System Config ────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
